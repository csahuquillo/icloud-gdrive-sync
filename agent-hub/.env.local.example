# =============================================================================
# .env.local.example — Plantilla de configuración / Configuration template
#
# Copia este archivo como .env.local y rellena tus valores reales.
# Copy this file as .env.local and fill in your real values.
#
# ⚠️ NUNCA subas .env.local a Git / NEVER commit .env.local to Git
# =============================================================================

# Google Cloud Project
# Obtenido en / Obtained from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Cuenta de Google principal / Main Google account
GOOGLE_ACCOUNT=your-email@gmail.com
